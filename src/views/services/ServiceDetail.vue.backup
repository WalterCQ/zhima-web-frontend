.contact-row { display: flex; align-items: center; gap: 8px; padding: 8px 0; color: #333; }
.contact-row .icon { width: 16px; height: 16px; color: #ff6b35; }
.contact-row .label { color: #666; min-width: 64px; font-size: 13px; }
