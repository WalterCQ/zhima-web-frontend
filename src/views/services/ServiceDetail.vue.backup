.btn-download { display: inline-block; padding: 7px 12px; border: 1px solid var(--primary-color, #FF6A00); color: var(--primary-color, #FF6A00); border-radius: 6px; font-size: 13px; text-decoration: none; min-width: 96px; }
.btn-download.active, .btn-download:hover { background: var(--primary-color, #FF6A00); color: #fff; }

