.app-btn { width: 100%; background: #f3f4f6; color: #333; border: 1px solid #e5e7eb; border-radius: 6px; padding: 10px 12px; cursor: pointer; font-weight: 600; display: inline-flex; align-items: center; justify-content: center; gap: 6px; }
